# Copy this file to .env.local and fill in values

# Optional: Notion official API secret for private pages
# Get it from https://www.notion.so/my-integrations
NOTION_API_SECRET=

# Optional: Redis caching for preview images
REDIS_HOST=
REDIS_PASSWORD=

# Optional: Fathom Analytics (privacy-friendly)
# Get your site ID at https://app.usefathom.com
NEXT_PUBLIC_FATHOM_ID=

# Optional: PostHog Analytics
# Get your project API key at https://app.posthog.com
NEXT_PUBLIC_POSTHOG_ID=
